run = "npm run dev"
modules = ["python-3.11", "nodejs-22", "postgresql-16"]

[nix]
channel = "stable-22_11"

[deployment]
deploymentTarget = "autoscale"
build = ["pnpm", "run", "build:deploy"]
run = ["bash", "scripts/start-deploy.sh"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 5000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Next.js Dev Server"

[[workflows.workflow]]
name = "Next.js Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run dev"
waitForPort = 5000

[agent]
expertMode = true
integrations = ["sendgrid:1.0.0"]

[userenv]

[userenv.shared]
