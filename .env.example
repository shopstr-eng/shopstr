# Database connection string
# For local development with docker-compose:
DATABASE_URL=postgresql://shopstr:shopstr@localhost:5432/shopstr

# Controls whether Testcontainers-based integration tests run.
# Set to exactly `1` to enable tests guarded by RUN_TESTCONTAINERS (requires Docker).
# Example: RUN_TESTCONTAINERS=1
#
# When enabled, some integration tests will start a real Postgres container
# via Testcontainers. Only enable in environments with Docker available.
RUN_TESTCONTAINERS=0

# Required for MCP agent onboarding when Shopstr stores encrypted nsec values
MCP_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Optional: override the public base URL used in MCP onboarding responses
# NEXT_PUBLIC_BASE_URL=https://shopstr.example

# from request headers if NEXT_PUBLIC_BASE_URL is not set
# MCP_ALLOWED_HOSTS=shopstr.example,api.shopstr.example

# Optional: trust X-Forwarded-For for rate limiting only when requests always
# pass through a reverse proxy that appends the real client IP.
# TRUST_PROXY_HEADERS=true
#
# Alternative: trust forwarded headers only from these direct proxy IPs.
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# For production, use your actual database URL:
# DATABASE_URL=postgresql://user:password@host:port/database

# Shopstr-controlled arbiter Cashu pubkey (32-byte hex) for 2-of-3 dispute escrow.
NEXT_PUBLIC_ARBITER_PUBKEY=replace-with-32-byte-hex-cashu-pubkey

# Arbiter's Nostr identity pubkey (hex) — distinct from the Cashu P2PK
# pubkey above. Routes escrow-dispute DMs and gates /disputes + its controls.
NEXT_PUBLIC_ARBITER_NOSTR_PUBKEY=replace-with-arbiter-nostr-pubkey-hex

# Arbiter's Nostr identity PRIVATE key (hex or nsec), server-only. Signs the
# NIP-59 seal on outgoing escrow-arbiter-sig DMs. This is a different key
# from ARBITER_PRIVKEY below — do not confuse the two.
ARBITER_NOSTR_PRIVKEY=replace-with-arbiter-nostr-privkey-hex-or-nsec

# Arbiter's Cashu P2PK signing key (hex), server-only. Produces the
# arbiter's P2PK signature share when resolving a 2-of-3 dispute.
ARBITER_PRIVKEY=replace-with-arbiter-cashu-privkey-hex

# Shared secret gating POST /api/arbiter/rule. Server-only.
ARBITER_API_SECRET=replace-with-long-random-secret

# Client-exposed copy of ARBITER_API_SECRET (must match exactly). Safe
# because /disputes is already gated to the arbiter's own logged-in Nostr
# identity (NEXT_PUBLIC_ARBITER_NOSTR_PUBKEY).
NEXT_PUBLIC_ARBITER_API_SECRET=replace-with-long-random-secret