# Database connection string
# For local development with docker-compose:
DATABASE_URL=postgresql://milkmarket:milkmarket@localhost:5432/milkmarket

# Required for MCP agent onboarding when Milk Market stores encrypted nsec values
MCP_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Optional: override the public base URL used in MCP onboarding responses
# NEXT_PUBLIC_BASE_URL=https://milkmarket.example

# from request headers if NEXT_PUBLIC_BASE_URL is not set
# MCP_ALLOWED_HOSTS=milkmarket.example,api.milkmarket.example

# For production, use your actual database URL:
# DATABASE_URL=postgresql://user:password@host:port/database
