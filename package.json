{
  "name": "milk-market",
  "version": "0.10.3",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=22.4.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=1024' next dev -p 5000",
    "dev:web": "pnpm run dev",
    "dev:mobile": "pnpm --filter @milk-market/mobile dev",
    "build": "next build",
    "build:web": "next build",
    "build:deploy": "bash scripts/deploy-build.sh",
    "start:deploy": "node .next/standalone/server.js",
    "build:all": "turbo run build --filter=@milk-market/mobile --filter=@milk-market/domain --filter=@milk-market/nostr --filter=@milk-market/api-client",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "dev:prod": "NODE_OPTIONS='--max-old-space-size=2048' next build && next start -H 0.0.0.0 -p 5000",
    "lint": "pnpm run lint:web && turbo run lint --filter=@milk-market/mobile --filter=@milk-market/domain --filter=@milk-market/nostr --filter=@milk-market/api-client",
    "lint:web": "eslint . --ext .ts,.tsx",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit --incremental false",
    "typecheck": "pnpm run typecheck:web && turbo run typecheck --filter=@milk-market/mobile --filter=@milk-market/domain --filter=@milk-market/nostr --filter=@milk-market/api-client",
    "typecheck:web": "tsc --noEmit --incremental false",
    "lint-all": "pnpm run typecheck:web && pnpm run lint:web",
    "test": "jest",
    "test:web": "jest",
    "test:all": "pnpm run test:web && turbo run test --filter=@milk-market/mobile --filter=@milk-market/domain --filter=@milk-market/nostr --filter=@milk-market/api-client",
    "test:ci": "jest --ci --runInBand",
    "test:coverage": "jest --coverage --ci --runInBand",
    "test:integration": "RUN_TESTCONTAINERS=1 jest utils/db/__tests__/db-service.test.ts --runInBand",
    "test:watch": "jest --watch",
    "prepare": "husky"
  },
  "dependencies": {
    "@braintree/sanitize-url": "7.1.2",
    "@cashu/cashu-ts": "4.4.0",
    "@ducanh2912/next-pwa": "10.2.9",
    "@getalby/lightning-tools": "8.1.1",
    "@getalby/sdk": "7.0.0",
    "@heroicons/react": "2.2.0",
    "@heroui/react": "2.8.10",
    "@milk-market/api-client": "file:./packages/api-client",
    "@milk-market/domain": "file:./packages/domain",
    "@milk-market/nostr": "file:./packages/nostr",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@noble/hashes": "1.3.1",
    "classnames": "2.5.1",
    "@sendgrid/mail": "8.1.6",
    "@stripe/react-stripe-js": "5.6.0",
    "@stripe/stripe-js": "8.8.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/formidable": "3.4.5",
    "@types/pg": "8.15.4",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "autoprefixer": "10.5.0",
    "chart.js": "4.5.1",
    "crypto-js": "4.2.0",
    "dexie": "4.4.2",
    "dexie-react-hooks": "4.4.0",
    "eslint": "10.4.0",
    "eslint-config-next": "16.2.6",
    "formidable": "3.5.4",
    "framer-motion": "12.38.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "nostr-tools": "2.23.3",
    "pdf-lib": "1.17.1",
    "pg": "8.20.0",
    "postcss": "8.5.13",
    "qrcode": "1.5.4",
    "react": "19.2.6",
    "react-chartjs-2": "5.3.1",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.0",
    "react-responsive-carousel": "3.2.23",
    "stripe": "19.0.0",
    "tailwindcss": "4.3.0",
    "uuid": "13.0.0",
    "ws": "8.19.0",
    "zod": "4.0.17"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/crypto-js": "4.2.2",
    "@types/jest": "30.0.0",
    "@types/node": "25.8.0",
    "@types/pg": "8.20.0",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "11.0.0",
    "babel-jest": "30.4.1",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "pg-mem": "3.0.14",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "testcontainers": "9.12.0",
    "turbo": "2.5.8",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": ">=10"
      }
    },
    "onlyBuiltDependencies": [
      "@heroui/shared-utils",
      "sharp",
      "unrs-resolver"
    ]
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "picomatch": "4.0.4",
    "postcss": "8.5.13"
  },
  "resolutions": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
