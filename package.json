{
  "name": "shopstr",
  "version": "0.10.3",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.4.0",
    "npm": ">=9.6.7"
  },
  "scripts": {
    "dev": "next dev -p 5000",
    "build": "next build",
    "build:deploy": "npm ci --prefer-offline --no-audit --no-fund && next build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && (rm -rf node_modules .next/cache .next/standalone/.next/cache /tmp/* 2>/dev/null || true)",
    "start:deploy": "HOSTNAME=0.0.0.0 PORT=${PORT:-3000} node .next/standalone/server.js",
    "start": "HOSTNAME=0.0.0.0 PORT=${PORT:-3000} node .next/standalone/server.js",
    "start:dev-server": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint . --ext .ts,.tsx",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "lint-all": "npm run type-check && npm run lint",
    "test": "jest",
    "test:ci": "jest --ci --runInBand",
    "test:coverage": "jest --coverage --ci --runInBand",
    "test:integration": "RUN_TESTCONTAINERS=1 jest utils/db/__tests__/db-service.test.ts --runInBand",
    "test:watch": "jest --watch",
    "prepare": "husky"
  },
  "dependencies": {
    "@braintree/sanitize-url": "7.1.2",
    "@cashu/cashu-ts": "4.5.1",
    "@ducanh2912/next-pwa": "10.2.9",
    "@getalby/lightning-tools": "8.1.1",
    "@getalby/sdk": "8.0.3",
    "@heroicons/react": "2.2.0",
    "@heroui/react": "2.8.10",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tailwindcss/postcss": "4.3.0",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "autoprefixer": "10.5.0",
    "chart.js": "4.5.1",
    "crypto-js": "4.2.0",
    "dexie": "4.4.3",
    "dexie-react-hooks": "4.4.0",
    "eslint": "10.4.1",
    "eslint-config-next": "16.2.7",
    "framer-motion": "12.40.0",
    "next": "16.2.7",
    "next-themes": "0.4.6",
    "nostr-tools": "2.23.5",
    "pg": "8.21.0",
    "postcss": "8.5.13",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-chartjs-2": "5.3.1",
    "react-dom": "19.2.7",
    "react-hook-form": "7.77.0",
    "react-responsive-carousel": "3.2.23",
    "tailwindcss": "4.3.0",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/crypto-js": "4.2.2",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "11.0.0",
    "babel-jest": "30.4.1",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "pg-mem": "3.0.14",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "picomatch": "4.0.4",
    "postcss": "8.5.13",
    "immutable": "4.3.8",
    "tar-fs": "2.1.4",
    "brace-expansion": "5.0.6",
    "qs": "6.15.2",
    "ws": "8.20.1"
  },
  "resolutions": {
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
