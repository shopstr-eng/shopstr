{
  "name": "milk-market",
  "version": "0.10.3",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -p 5000",
    "dev:web": "pnpm run dev",
    "dev:mobile": "pnpm --filter @milk-market/mobile dev",
    "build": "next build",
    "build:web": "next build",
    "build:all": "turbo run build --filter=@milk-market/mobile --filter=@milk-market/domain --filter=@milk-market/nostr --filter=@milk-market/api-client",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "pnpm run lint:web && turbo run lint --filter=@milk-market/mobile --filter=@milk-market/domain --filter=@milk-market/nostr --filter=@milk-market/api-client",
    "lint:web": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit --incremental false",
    "typecheck": "pnpm run typecheck:web && turbo run typecheck --filter=@milk-market/mobile --filter=@milk-market/domain --filter=@milk-market/nostr --filter=@milk-market/api-client",
    "typecheck:web": "tsc --noEmit --incremental false",
    "lint-all": "pnpm run typecheck:web && pnpm run lint:web",
    "test": "jest",
    "test:web": "jest",
    "test:all": "pnpm run test:web && turbo run test --filter=@milk-market/mobile --filter=@milk-market/domain --filter=@milk-market/nostr --filter=@milk-market/api-client",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@braintree/sanitize-url": "7.1.0",
    "@cashu/cashu-ts": "2.1.0",
    "@ducanh2912/next-pwa": "10.2.9",
    "@getalby/lightning-tools": "5.0.1",
    "@getalby/sdk": "5.1.2",
    "@heroicons/react": "2.1.1",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@nextui-org/react": "2.2.9",
    "@sendgrid/mail": "8.1.6",
    "@stripe/react-stripe-js": "5.6.0",
    "@stripe/stripe-js": "8.8.0",
    "@types/formidable": "3.4.5",
    "@types/pg": "8.15.4",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "autoprefixer": "10.4.14",
    "chart.js": "4.5.1",
    "crypto-js": "4.2.0",
    "dexie": "3.2.4",
    "dexie-react-hooks": "1.1.7",
    "eslint": "8.57.0",
    "eslint-config-next": "13.3.0",
    "formidable": "3.5.4",
    "framer-motion": "10.16.4",
    "next": "16.1.7",
    "next-themes": "0.2.1",
    "nostr-tools": "2.7.1",
    "pdf-lib": "1.17.1",
    "pg": "8.16.3",
    "postcss": "8.4.31",
    "qrcode": "1.5.3",
    "react": "18.2.0",
    "react-chartjs-2": "5.3.1",
    "react-dom": "18.2.0",
    "react-hook-form": "7.47.0",
    "react-responsive-carousel": "3.2.23",
    "stripe": "19.0.0",
    "tailwindcss": "3.3.1",
    "uuid": "9.0.0",
    "ws": "8.19.0",
    "@milk-market/domain": "file:./packages/domain",
    "@milk-market/nostr": "file:./packages/nostr",
    "@milk-market/api-client": "file:./packages/api-client"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/crypto-js": "4.2.2",
    "@types/jest": "29.5.14",
    "@types/node": "20.7.0",
    "@types/pg": "8.11.4",
    "@types/qrcode": "1.5.5",
    "@types/react": "18.2.22",
    "@types/react-dom": "18.0.11",
    "@types/uuid": "9.0.4",
    "babel-jest": "30.0.4",
    "eslint-config-prettier": "9.1.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "30.2.0",
    "prettier": "3.1.0",
    "prettier-plugin-tailwindcss": "0.5.7",
    "turbo": "2.5.8",
    "typescript": "5.2.2"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "picomatch": "4.0.4"
  },
  "resolutions": {
    "@types/react": "18.2.22",
    "@types/react-dom": "18.0.11"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
