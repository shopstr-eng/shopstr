{
  "name": "shopstr",
  "version": "0.10.3",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.4.0",
    "npm": ">=9.6.7"
  },
  "scripts": {
    "dev": "next dev -p 5000",
    "build": "next build",
    "build:deploy": "npm ci --prefer-offline --no-audit --no-fund && next build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && rm -rf node_modules .next/cache .next/standalone/.next/cache /tmp/* 2>/dev/null; true",
    "start:deploy": "HOSTNAME=0.0.0.0 PORT=${PORT:-3000} node .next/standalone/server.js",
    "start": "HOSTNAME=0.0.0.0 PORT=${PORT:-3000} node .next/standalone/server.js",
    "start:dev-server": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint . --ext .ts,.tsx",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "lint-all": "npm run type-check && npm run lint",
    "test": "jest",
    "test:ci": "jest --ci --runInBand",
    "test:coverage": "jest --coverage --ci --runInBand",
    "test:watch": "jest --watch",
    "prepare": "husky"
  },
  "dependencies": {
    "@braintree/sanitize-url": "7.1.2",
    "@cashu/cashu-ts": "4.1.0",
    "@ducanh2912/next-pwa": "10.2.9",
    "@getalby/lightning-tools": "8.1.0",
    "@getalby/sdk": "7.0.0",
    "@heroicons/react": "2.2.0",
    "@heroui/react": "3.0.3",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tailwindcss/postcss": "4.2.2",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "autoprefixer": "10.4.27",
    "chart.js": "4.5.1",
    "crypto-js": "4.2.0",
    "dexie": "4.4.2",
    "dexie-react-hooks": "4.4.0",
    "eslint": "10.2.0",
    "eslint-config-next": "13.3.0",
    "framer-motion": "12.38.0",
    "next": "16.2.3",
    "next-themes": "0.4.6",
    "nostr-tools": "2.23.3",
    "pg": "8.20.0",
    "postcss": "8.5.10",
    "qrcode": "1.5.4",
    "react": "19.2.5",
    "react-chartjs-2": "5.3.1",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "react-responsive-carousel": "3.2.23",
    "tailwindcss": "4.2.2",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/crypto-js": "4.2.2",
    "@types/jest": "30.0.0",
    "@types/node": "20.7.0",
    "@types/pg": "8.20.0",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "11.0.0",
    "babel-jest": "30.3.0",
    "eslint-config-prettier": "9.1.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "prettier": "3.8.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "typescript": "6.0.2"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "picomatch": "4.0.4"
  },
  "resolutions": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
