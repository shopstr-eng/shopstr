.env
.env.local
.env*.local
.env.development
.env.test

# Editor / OS junk
.DS_Store
*.pem
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vscode
.idea

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Docs / planning / agent scratch (not needed at runtime)
.local
.agents
attached_assets
docs
*.md
!README.md
threat_model.md

